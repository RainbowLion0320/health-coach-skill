# ClawHub ignore patterns
# These files/directories will be excluded when publishing to ClawHub

# User data - CRITICAL: never upload personal data
data/
backups/
*.db
*.db-journal
*.db-wal
*.db-shm

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environments
env/
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp
